<Window x:Class="Arduino.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Arduino Academy" Height="700" Width="1200" Background="#F3F4F6" FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="15">
                    <TextBlock Text="Arduino" FontSize="14" FontFamily="Noto Sans Georgian"/>
                    <TextBlock Text="Networking Academy" FontWeight="Bold" FontSize="14" FontFamily="Noto Sans Georgian Bold"/>
                    <TextBlock Text="ITA_I2X_24-28" Foreground="Gray" FontSize="12" FontFamily="Franklin Gothic Book"/>
                </StackPanel>
                
                <TreeView x:Name="CourseTree" MouseDoubleClick="CourseTree_MouseDoubleClick" Margin="5">
                    <!-- VZOR NA MODULY
                    <TreeViewItem Header="Modul 0: Lorem ipsum" IsExpanded="True" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem Header="0.0 Lorem ipsum dolor sit amet" Tag="0.0" FontWeight="Normal"/>
                    </TreeViewItem>
                    VZOR NA MODULY -->

                    <TreeViewItem Header="Modul 1: Úvod do Arduina" IsExpanded="True" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem Header="1.0 Co je to Arduino?" Tag="1.0" FontWeight="Normal"/>
                        <TreeViewItem Header="1.1 Historie a využití Arduina" Tag="1.1" FontWeight="Normal"/>
                        <TreeViewItem Header="1.2 Arduino desky" Tag="1.2" FontWeight="Normal"/>
                        <TreeViewItem Header="1.3 Arduino IDE" Tag="1.3" FontWeight="Normal"/>
                    </TreeViewItem>

                    <!-- <TreeViewItem Header="Modul 2: Opakování elektrotechniky" IsExpanded="True" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem Header="2.0 Napětí, proud a odpor" Tag="2.0" FontWeight="Normal"/>
                        <TreeViewItem Header="2.1 Ohmův zákon" Tag="2.1" FontWeight="Normal"/>
                        <TreeViewItem Header="2.2 Základní součástky" Tag="2.2" FontWeight="Normal"/>
                    </TreeViewItem>

                    <TreeViewItem Header="Modul 3: Programování" IsExpanded="True" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem Header="3.0 Struktura programu" Tag="3.0" FontWeight="Normal"/>
                    </TreeViewItem> -->
                </TreeView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                <TextBlock x:Name="ArticleTitle" Text="Vyberte si kurz" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10"/>
            </Border>

            <ScrollViewer Grid.Row="1">
                <StackPanel Margin="15" MaxWidth="800">
                    <TextBlock x:Name="ArticleContent" Text="Vyberte si kurz z modulů a začněte." TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>