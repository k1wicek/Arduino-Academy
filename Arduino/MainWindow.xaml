<Window x:Class="Arduino.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Arduino Academy" Height="700" Width="1200" Background="#F3F4F6" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Background" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Foreground" Color="#FFE9E3FF"/>
        <SolidColorBrush x:Key="Text" Color="#FF000000"/>
        <SolidColorBrush x:Key="Text2" Color="#FF878787"/>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource Background}"  Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Arduino" Foreground="{DynamicResource Text}" FontSize="14" FontFamily="Noto Sans Georgian"/>
                        <TextBlock Text="Networking Academy" Foreground="{DynamicResource Text}" FontWeight="Bold" FontSize="14" FontFamily="Noto Sans Georgian Bold"/>
                        <TextBlock Text="ITA_I2X_24-28" Foreground="{DynamicResource Text2}" FontSize="12" FontFamily="Franklin Gothic Book"/>
                    </StackPanel>


                    <StackPanel Grid.Column="1" Margin="10,0,0,0">

                        <Button x:Name="ModeButton" Background="{DynamicResource Foreground}" Content="⏾" Foreground="{DynamicResource Text}"  Width="25" Height="25" VerticalAlignment="Top" Click="ModeButton_Click">
                            <Button.ToolTip>
                                <StackPanel>
                                    <TextBlock x:Name="ModeTextBlock"
                           Text="Tmavý režim"
                           FontWeight="Bold"/>
                                </StackPanel>
                            </Button.ToolTip>
                        </Button>

                        <Button x:Name="LanguageButton" Background="{DynamicResource Foreground}" Content="CZ" Foreground="{DynamicResource Text}" Width="25" Height="25" Margin="0,5,0,0" Click="LanguageButton_Click">
                            <Button.ToolTip>
                                <TextBlock x:Name="LanguageTextBox" Text="Změnit jazyk na EN" FontWeight="Bold"/>
                            </Button.ToolTip>
                        </Button>

                    </StackPanel>
                </Grid>

                <TreeView x:Name="CourseTree" FocusVisualStyle="{x:Null}" Background="{DynamicResource Foreground}" BorderThickness="0" MouseDoubleClick="CourseTree_MouseDoubleClick" Margin="5">

                    <TreeViewItem x:Name="Module1" Header="Modul 1: Úvod do Arduina" Foreground="{DynamicResource Text}" IsExpanded="False" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem x:Name="Item10" Header="1.0 Co je to Arduino?" Foreground="{DynamicResource Text}" Tag="1.0" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item11" Header="1.1 Historie a využití Arduina" Foreground="{DynamicResource Text}" Tag="1.1" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item12" Header="1.2 Arduino desky" Foreground="{DynamicResource Text}" Tag="1.2" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item13" Header="1.3 Arduino IDE" Foreground="{DynamicResource Text}" Tag="1.3" FontWeight="Normal"/>
                    </TreeViewItem>

                    <TreeViewItem x:Name="Module2" Header="Modul 2: Opakování elektrotechniky" Foreground="{DynamicResource Text}" IsExpanded="False" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem x:Name="Item20" Header="2.0 Napětí, proud a odpor" Foreground="{DynamicResource Text}" Tag="2.0" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item21" Header="2.1 Ohmův zákon" Foreground="{DynamicResource Text}" Tag="2.1" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item22" Header="2.2 Základní součástky" Foreground="{DynamicResource Text}" Tag="2.2" FontWeight="Normal"/>
                    </TreeViewItem>

                    <TreeViewItem x:Name="Module3" Header="Modul 3: Komunikační protokoly" Foreground="{DynamicResource Text}" IsExpanded="False" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem x:Name="Item30" Header="3.0 UART" Foreground="{DynamicResource Text}" Tag="3.0" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item31" Header="3.1 SPI" Foreground="{DynamicResource Text}" Tag="3.1" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item32" Header="3.2 I2C" Foreground="{DynamicResource Text}" Tag="3.2" FontWeight="Normal"/>
                    </TreeViewItem>

                    <TreeViewItem x:Name="Module4" Header="Modul 4: Programování v Arduino" Foreground="{DynamicResource Text}" IsExpanded="False" FontFamily="Segoe UI" FontWeight="Bold">
                        <TreeViewItem x:Name="Item40" Header="4.0 Skica" Foreground="{DynamicResource Text}" Tag="4.0" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item41" Header="4.1 Vstupy a výstupy" Foreground="{DynamicResource Text}" Tag="4.1" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item42" Header="4.2 Datové typy" Foreground="{DynamicResource Text}" Tag="4.2" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item43" Header="4.3 Cykly a podmínky" Foreground="{DynamicResource Text}" Tag="4.3" FontWeight="Normal"/>
                        <TreeViewItem x:Name="Item44" Header="4.4 Funkce" Foreground="{DynamicResource Text}" Tag="4.4" FontWeight="Normal"/>
                    </TreeViewItem>

                </TreeView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource Background}"  BorderBrush="{DynamicResource Foreground}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="ArticleTitle" Text="Vyberte si kurz" Foreground="{DynamicResource Text}"  FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10"/>
            </Border>

            <ScrollViewer Grid.Row="1" Background="{DynamicResource Foreground}">
                <StackPanel Margin="15" MaxWidth="800">
                    <TextBlock x:Name="ArticleContent" Text="Vyberte si kurz z modulů a začněte." Foreground="{DynamicResource Text}"  TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>